Fix two regex patterns that contain invalid JSON escape sequences.

`\w` and `\.` aren't valid JSON string escapes per RFC 8259; strict
parsers (jq, Go's encoding/json with DisallowUnknownEscapes) reject
them. The patterns clearly intend regex escapes, so each offending
backslash is doubled to produce a valid JSON string that decodes to
the same regex.

--- a/rules/lfi.json
+++ b/rules/lfi.json
@@ -22,7 +22,7 @@
   {
         "id": "lfi-absolute-paths",
         "phase": 2,
-        "pattern": "(?i)^(?:(?:/\\w+)+)(?:(?:/\\w+)?)+?\\.[\w]+$",
+        "pattern": "(?i)^(?:(?:/\\w+)+)(?:(?:/\\w+)?)+?\\.[\\w]+$",
         "targets": ["URI", "ARGS", "HEADERS"],
          "severity": "MEDIUM",
         "action": "log",
--- a/rules/rfi.json
+++ b/rules/rfi.json
@@ -134,7 +134,7 @@
   {
     "id":"rfi-open-basedir-bypass",
      "phase":2,
-    "pattern":"(?i)(?:file:\/\/|\.\.\\/){5,}",
+    "pattern":"(?i)(?:file:\/\/|\\.\\.\\/){5,}",
     "targets": ["URI","ARGS", "HEADERS"],
     "severity":"MEDIUM",
     "action":"log",
